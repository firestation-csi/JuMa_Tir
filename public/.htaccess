Options +FollowSymLinks -Indexes -MultiViews

# Zeichensatz erzwingen
AddDefaultCharset UTF-8

# ---- URL-Rewriting ----
RewriteEngine On

# HTTPS erzwingen (im Produktivbetrieb einkommentieren)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Direkte Anfragen auf vorhandene Dateien/Verzeichnisse durchlassen
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Alles andere an index.php weiterleiten
RewriteRule ^ index.php [L,QSA]

# ---- Sicherheits-Header ----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=self"

    # Service Worker darf nur vom gleichen Origin geladen werden
    <FilesMatch "sw\.js$">
        Header set Service-Worker-Allowed "/"
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

# ---- Caching für statische Assets ----
<IfModule mod_expires.c>
    ExpiresActive On

    # CSS und JS: 1 Woche (bei Änderungen Dateinamen versionieren)
    ExpiresByType text/css              "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"

    # Bilder: 1 Monat
    ExpiresByType image/png             "access plus 1 month"
    ExpiresByType image/jpeg            "access plus 1 month"
    ExpiresByType image/svg+xml         "access plus 1 month"
    ExpiresByType image/webp            "access plus 1 month"

    # Manifest und Icons: 1 Tag
    ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>

# ---- Komprimierung ----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json application/manifest+json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---- Zugriff auf sensitive Dateien sperren ----
# .json explizit NICHT blockieren, da manifest.json öffentlich sein muss
<FilesMatch "\.(env|log|sql|lock|gitignore)$">
    Require all denied
</FilesMatch>
